# ── Sensitive data (NEVER commit) ─────────────────────────────
# Broker statements contain account numbers, addresses, names.
# They stay on your machine; only the sanitised JSON is pushed.
*.pdf
*.xlsx
*.xls
portfolio/inbox/
data/statements/
private/

# ── Local Python ──────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo

# ── Editors / OS ──────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Local-only output that shouldn't reach prod ───────────────
*.log
*.tmp

# ── History CSVs — tracked in git but excluded from diff noise ──
# To view history size: git ls-files data/history/ | wc -l
# These ARE committed — just suppressed in default diff output
